<!-- LA Dashboard -->
<div class="la-page-header">
  <div>
    <h1 class="la-page-title">Dashboard</h1>
    <p class="la-page-subtitle">Manage customer conversations in real-time</p>
  </div>
  <div class="la-header-stats">
    <div class="la-stat-chip la-stat-queue">
      <span class="la-stat-number" id="queue-count" data-la-queue-target="count"><%= @queue_conversations.count %></span>
      <span class="la-stat-label">In Queue</span>
    </div>
    <div class="la-stat-chip la-stat-active">
      <span class="la-stat-number"><%= @active_conversations.count %></span>
      <span class="la-stat-label">My Active</span>
    </div>
  </div>
</div>

<div class="la-dashboard-grid" data-controller="la-queue">
  <!-- Queue Panel -->
  <section class="la-panel">
    <div class="la-panel-header">
      <h2 class="la-panel-title">
        <span class="la-panel-dot la-panel-dot--amber"></span>
        Awaiting Agent
      </h2>
      <span class="la-badge la-badge--amber" id="queue-badge" data-la-queue-target="badge"><%= @queue_conversations.count %></span>
    </div>

    <div class="la-queue-list" id="la-queue-list" data-la-queue-target="list">
      <% if @queue_conversations.empty? %>
        <div class="la-empty-state" id="queue-empty" data-la-queue-target="empty">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="la-empty-icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
          </svg>
          <p>No customers waiting</p>
          <span>New chats will appear here automatically</span>
        </div>
      <% else %>
        <% @queue_conversations.each do |conv| %>
          <%= render "la/conversations/queue_card", conversation: conv %>
        <% end %>
      <% end %>
    </div>
  </section>

  <!-- My Active Chats Panel -->
  <section class="la-panel">
    <div class="la-panel-header">
      <h2 class="la-panel-title">
        <span class="la-panel-dot la-panel-dot--green"></span>
        My Active Chats
      </h2>
      <span class="la-badge la-badge--green"><%= @active_conversations.count %></span>
    </div>

    <div class="la-queue-list">
      <% if @active_conversations.empty? %>
        <div class="la-empty-state">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="la-empty-icon">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <p>No active chats</p>
          <span>Accept a chat from the queue to get started</span>
        </div>
      <% else %>
        <% @active_conversations.each do |conv| %>
          <div class="la-queue-card la-queue-card--active">
            <div class="la-queue-card-header">
              <div class="la-customer-avatar"><%= (conv.customer_name.presence || "?")[0].upcase %></div>
              <div class="la-customer-info">
                <span class="la-customer-name"><%= conv.customer_name.presence || "Anonymous" %></span>
                <span class="la-customer-email"><%= conv.customer_email.presence || "No email provided" %></span>
              </div>
              <span class="la-status-pill la-status-pill--active">Active</span>
            </div>
            <div class="la-queue-card-actions">
              <%= link_to "Open Chat →", la_conversation_path(conv), class: "la-btn la-btn-sm la-btn-ghost" %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>
</div>
