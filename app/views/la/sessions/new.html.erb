<!-- LA Portal Login Page -->
<div class="la-login-wrapper">
  <div class="la-login-card">
    <div class="la-login-logo">
      <div class="la-brand-logo la-brand-logo--large">OL</div>
    </div>
    <h1 class="la-login-title">Loan Advocate Portal</h1>
    <p class="la-login-subtitle">Sign in to manage customer conversations</p>

    <%= form_with url: la_session_path, method: :post, class: "la-login-form", data: { turbo: false } do |f| %>
      <div class="la-form-group">
        <label for="email" class="la-label">Email Address</label>
        <input
          type="email"
          id="email"
          name="email"
          class="la-input"
          placeholder="agent@opploans.com"
          required
          autocomplete="email"
        >
      </div>

      <div class="la-form-group">
        <label for="password" class="la-label">Password</label>
        <input
          type="password"
          id="password"
          name="password"
          class="la-input"
          placeholder="••••••••"
          required
          autocomplete="current-password"
        >
      </div>

      <button type="submit" class="la-btn la-btn-primary la-btn-full">
        Sign In
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" style="width:18px;height:18px;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </button>
    <% end %>
  </div>
</div>
